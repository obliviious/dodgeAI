PORT=4000
DATABASE_URL=postgresql://o2c:o2c_secret@localhost:5432/o2c
# Creates / updates O2C tables + chat_conversations / chat_messages (also runs on API startup).
# npm run db:migrate
# Aiven / TLS (local: backend/ca.pem or PGSSL_CA path)
# Vercel / serverless: put PEM in env — multiline OK in Vercel dashboard
# DATABASE_SSL_CA_PEM=
# Or base64: DATABASE_SSL_CA_BASE64=
# PGSSL_CA=
# DATABASE_SSL_CA=
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=o2c_neo4j_secret
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DATA_DIR=../sap-o2c-data
